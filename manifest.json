{
  "manifest_version": 3,
  "name": "Word — 单词查询",
  "version": "1.0.0",
  "description": "Chrome 单词查询插件，调用 DeepSeek 模型返回音标、释义、例句等内容",
  "permissions": ["storage"],
  "host_permissions": ["https://api.deepseek.com/*"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "单词查询",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options/options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
